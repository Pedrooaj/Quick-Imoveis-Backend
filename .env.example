# JWT – access token
JWT_SECRET=sua-chave-secreta-mude-em-producao
# Validade do access token (ex.: 15m, 1h). Padrão: 15m
JWT_EXPIRATION=15m

# Frontend (para links de verificação de e-mail, etc.)
FRONTEND_URL=http://localhost:3001

# Banco de dados
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Google OAuth – Login com Google (POST /auth/google)
# Obter em: Google Cloud Console > APIs e serviços > Credenciais > OAuth 2.0 Client ID
# Tipo: Aplicativo da Web
# URIs de redirecionamento: http://localhost:3000/api/auth/callback/google (dev) ou https://seu-dominio.com/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret

# Firebase Admin SDK
# Opção 1 (produção/Render): JSON inline da service account
# FIREBASE_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
#
# Opção 2 (local): caminho para o arquivo de credenciais
# GOOGLE_APPLICATION_CREDENTIALS=firebase.json

# SMTP / Nodemailer
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=true
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="Quick Imóveis <noreply@exemplo.com>"

# Firebase Storage – bucket para armazenar imagens (avatares e imóveis)
# Formato: nome-do-projeto.firebasestorage.app
# FIREBASE_STORAGE_BUCKET=quick-imoveis-8005d.firebasestorage.app
